{
  "cli": {
    "version": ">= 19.0.8",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "withoutCredentials": true,
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "withoutCredentials": true,
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "autoIncrement": false,
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
