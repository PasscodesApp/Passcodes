<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:text="Unofficial Release | Preview Release"
        android:textAlignment="center"
        android:textSize="32sp"
        android:textColor="?attr/colorError"
        android:layout_marginVertical="24sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:text="Support to this release will be very minimal.. consider moving to a official release.."
        android:textAlignment="center"
        android:textSize="16sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="16sp"/>

    <TextView
        android:text="Website:- https://passcodesapp.github.io/Passcodes-Website/"
        android:textAlignment="center"
        android:textSize="16sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autoLink="web" />

</LinearLayout>
